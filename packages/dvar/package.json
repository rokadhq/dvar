{
  "name": "@rokadhq/dvar",
  "version": "0.7.0-alpha.0",
  "description": "Policy firewall for AI agents, tool calls, and MCP connections.",
  "keywords": [
    "ai-agent",
    "security",
    "policy",
    "mcp",
    "authorization",
    "guardrails"
  ],
  "homepage": "https://github.com/rokadhq/dvar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rokadhq/dvar.git"
  },
  "bugs": {
    "url": "https://github.com/rokadhq/dvar/issues"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "schema",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "SUPPORT.md",
    "API_STABILITY.md",
    "LICENSE"
  ],
  "bin": {
    "dvar": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": "./schema/dvar.policy.schema.json",
    "./package.json": "./package.json",
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    },
    "./approvals": {
      "types": "./dist/approvals.d.ts",
      "import": "./dist/approvals.js",
      "require": "./dist/approvals.cjs"
    },
    "./runtime-safety": {
      "types": "./dist/runtime-safety.d.ts",
      "import": "./dist/runtime-safety.js",
      "require": "./dist/runtime-safety.cjs"
    },
    "./stdio": {
      "types": "./dist/stdio.d.ts",
      "import": "./dist/stdio.js",
      "require": "./dist/stdio.cjs"
    },
    "./output-guard": {
      "types": "./dist/output-guard.d.ts",
      "import": "./dist/output-guard.js",
      "require": "./dist/output-guard.cjs"
    },
    "./adapters/vercel-ai-sdk": {
      "types": "./dist/vercel-ai-sdk.d.ts",
      "import": "./dist/vercel-ai-sdk.js",
      "require": "./dist/vercel-ai-sdk.cjs"
    },
    "./adapters/conformance": {
      "types": "./dist/adapter-conformance.d.ts",
      "import": "./dist/adapter-conformance.js",
      "require": "./dist/adapter-conformance.cjs"
    },
    "./adapters/openai-agents": {
      "types": "./dist/openai-agents.d.ts",
      "import": "./dist/openai-agents.js",
      "require": "./dist/openai-agents.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.8.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
