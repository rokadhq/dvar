{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dvar.rokad.co/schema/policy-v1.json",
  "title": "Dvar policy schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mode",
    "defaultEffect"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "mode": {
      "enum": [
        "off",
        "monitor",
        "enforce",
        "strict"
      ]
    },
    "defaultEffect": {
      "enum": [
        "allow",
        "deny",
        "require_approval"
      ]
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "onEvaluationError": {
          "enum": [
            "allow",
            "deny"
          ]
        },
        "onDecisionTimeout": {
          "enum": [
            "allow",
            "deny"
          ]
        },
        "onOutputFilterError": {
          "enum": [
            "allow",
            "deny"
          ]
        },
        "onTelemetryError": {
          "enum": [
            "continue",
            "deny"
          ]
        },
        "onApprovalProviderError": {
          "enum": [
            "allow",
            "deny"
          ]
        },
        "maxDecisionMs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60000
        },
        "maxToolCallsPerTask": {
          "type": "integer",
          "minimum": 1
        },
        "maxDepth": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "action",
          "expect"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "object"
          },
          "expect": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "effect"
            ],
            "properties": {
              "effect": {
                "enum": [
                  "allow",
                  "deny",
                  "require_approval"
                ]
              },
              "ruleId": {
                "type": "string"
              },
              "reasonCode": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "matcher": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "equals": {},
        "notEquals": {},
        "in": {
          "type": "array"
        },
        "notIn": {
          "type": "array"
        },
        "containsAny": {
          "type": "array"
        },
        "containsAll": {
          "type": "array"
        },
        "exists": {
          "type": "boolean"
        },
        "greaterThan": {
          "type": "number"
        },
        "greaterThanOrEqual": {
          "type": "number"
        },
        "lessThan": {
          "type": "number"
        },
        "lessThanOrEqual": {
          "type": "number"
        },
        "prefix": {
          "type": "string"
        },
        "suffix": {
          "type": "string"
        },
        "matches": {
          "type": "string",
          "maxLength": 256
        },
        "equalsContext": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "matchValue": {
      "anyOf": [
        {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          }
        },
        {
          "$ref": "#/$defs/matcher"
        }
      ]
    },
    "matchRecord": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/matchValue"
      }
    },
    "obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object"
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "effect"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9._-]+$"
        },
        "priority": {
          "type": "integer",
          "minimum": -100000,
          "maximum": 100000
        },
        "effect": {
          "enum": [
            "allow",
            "deny",
            "require_approval"
          ]
        },
        "when": {
          "$ref": "#/$defs/matchRecord"
        },
        "constraints": {
          "$ref": "#/$defs/matchRecord"
        },
        "obligations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/obligation"
          }
        },
        "approval": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "provider": {
              "type": "string"
            },
            "expiresInSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "bind": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "message": {
          "type": "string",
          "maxLength": 1000
        }
      }
    }
  }
}
